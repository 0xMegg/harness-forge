{
  "version": "1.0.0",
  "enabled": true,
  "cooldown_minutes": 60,

  "sources": {
    "web_fetch": {
      "enabled": true,
      "targets": [
        {"name": "GitHub Trending", "url": "https://github.com/trending", "type": "github_trending"},
        {"name": "GitHub Trending (Shell)", "url": "https://github.com/trending/shell", "type": "github_trending"}
      ]
    },
    "web_search": {
      "enabled": true,
      "queries": [
        "Claude Code best practices 2026",
        "AI coding assistant workflow automation",
        "developer harness self-improvement"
      ]
    },
    "manual": {
      "enabled": true,
      "description": "/harvest validate <description> or --file <path> for manual input"
    },
    "internal_feedback": {
      "enabled": true,
      "source_dir": "outputs/evaluations/",
      "pattern": "Lessons Learned"
    }
  },

  "fitness_filter": {
    "threshold": 6,
    "axes": {
      "automation": {"weight": 2, "description": "Does it reduce manual steps?"},
      "friction": {"weight": 2, "description": "Does it prevent existing pitfalls from gotchas.md?"},
      "hard_conversion": {"weight": 2, "description": "Can it be enforced via bash exit code?"},
      "token_efficiency": {"weight": 2, "description": "Does it reduce prompt/context size?"},
      "measurability": {"weight": 2, "description": "Can it be tracked with a single metric?"}
    }
  },

  "auto_apply": {
    "min_score": 7,
    "allowed_types": ["rule", "scaffold-rule"],
    "max_risk": "low"
  },

  "measurement": {
    "command": "bash scripts/harness-report.sh quick --target src/",
    "baseline_file": "harvest/baseline.json"
  },

  "output": {
    "provider": "log-only",
    "log_dir": "harvest/reports/",
    "notion": {
      "enabled": false,
      "database_id": ""
    },
    "obsidian": {
      "enabled": false,
      "vault_path": "",
      "folder": "harvest-reports"
    }
  },

  "dedup": {
    "seen_file": "harvest/.seen.json",
    "ttl_days": 30
  }
}
